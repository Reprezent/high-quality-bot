# Discord bot token from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: register slash commands in a single guild for near-instant updates.
# Leave empty to register commands globally across all guilds.
DISCORD_GUILD_ID=

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=botuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=highqualitybot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# Wowsims async API base URL used by the bot
WOWSIMS_API_BASE_URL=http://127.0.0.1:3333
